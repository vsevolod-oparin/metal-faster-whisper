<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: MetalWhisper loads third-party dylibs (CTranslate2, ONNX Runtime)
         that are signed with a different team or ad-hoc. Without this, the hardened
         runtime rejects dlopen() at launch. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required: CTranslate2 Metal backend compiles MSL shaders at runtime via
         MTLDevice newLibraryWithSource:. Metal's JIT compiler needs executable
         memory pages. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
